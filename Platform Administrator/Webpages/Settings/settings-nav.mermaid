    %% Styling
    classDef mainSection fill:#f9f,stroke:#333,stroke-width:2px
    classDef subSection fill:#bbf,stroke:#333,stroke-width:1px
    classDef feature fill:#dfd,stroke:#333,stroke-width:1px
    
    class Settings,MyAccount,Documentation,Legal mainSection
    class Profile,Notifications,SalesCode,Security,Manuals,FAQs,KnowledgeBase,Terms,Privacy,Compliance subSection
