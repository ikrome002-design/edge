stateDiagram-v2
    [*] --> DashboardAnalytics: Administrator Access
    
    state DashboardAnalytics {
        [*] --> KeyMetrics
        
        state KeyMetrics {
            state Performance {
                TotalSales: Real-time Sales Metrics
                MonthlyTargets: Goal Tracking
                RevenueMetrics: Revenue Analysis
                CommissionStats: Commission Tracking
            }
            
            state ActivityMonitoring {
                RecentActivities: Activity Timeline
                UserEngagement: User Session Data
                SalesProgress: Sales Pipeline Status
                TaskCompletion: Task Completion Rates
            }
            
            state AnalyticsVisuals {
                PerformanceCharts: Interactive Charts
                TrendAnalysis: Trend Visualization
                ComparisonTools: Benchmarking Tools
                ForecastModels: Predictive Analytics
            }
        }
        
        state RealTimeAlerts {
            state SystemNotifications {
                SystemAlerts: Platform Status
                SecurityAlerts: Security Events
                IntegrationAlerts: Integration Health
                PerformanceAlerts: Performance Issues
            }
            
            state UserNotifications {
                UserAlerts: User Activities
                AccessAlerts: Access Attempts
                SessionAlerts: Session Status
                FraudAlerts: Suspicious Activity
            }
            
            state AutomatedResponses {
                AlertPrioritization: Priority Sorting
                AlertRouting: Team Assignment
                AlertEscalation: Issue Escalation
                ResponseTracking: Alert Resolution
            }
        }
        
        state ReportGeneration {
            state StandardReports {
                SalesReports: Sales Analytics
                UserReports: User Activities
                SecurityReports: Security Logs
                ComplianceReports: Compliance Status
            }
            
            state CustomReporting {
                ReportBuilder: Custom Builder
                DataFilters: Filter Options
                Scheduling: Report Scheduling
                Distribution: Report Sharing
            }
            
            state ExportOptions {
                PDF: PDF Format
                CSV: CSV Format
                Scheduling: Automated Exports
                HistoricalData: Archive Access
            }
        }
        
        state SystemHealth {
            state PlatformMetrics {
                ServerHealth: Server Status
                DatabaseHealth: Database Performance
                APIStatus: API Health
                CacheStatus: Cache Performance
            }
            
            state IntegrationHealth {
                ThirdPartyStatus: Integration Status
                DataSync: Sync Health
                ConnectorStatus: Connector Status
                ServiceUptime: Service Availability
            }
            
            state ResourceUtilization {
                CPUUsage: CPU Metrics
                MemoryUsage: Memory Stats
                StorageStatus: Storage Usage
                NetworkMetrics: Network Health
            }
        }
        
        KeyMetrics --> RealTimeAlerts: Monitor & Alert
        RealTimeAlerts --> ReportGeneration: Generate Reports
        SystemHealth --> RealTimeAlerts: Status Updates
        KeyMetrics --> ReportGeneration: Data Export
        SystemHealth --> KeyMetrics: Performance Data
    }
    
    note right of KeyMetrics
        Real-time performance tracking
        Interactive analytics dashboard
        Historical data comparison
        Customizable metrics display
    end note
    
    note right of RealTimeAlerts
        Proactive system monitoring
        Instant notification system
        Alert prioritization
        Automated response triggers
    end note
    
    note right of ReportGeneration
        Custom report builder
        Multiple export formats
        Scheduled reporting
        Data visualization tools
    end note
    
    note right of SystemHealth
        Comprehensive health monitoring
        Integration status tracking
        Resource utilization metrics
        Performance optimization
    end note